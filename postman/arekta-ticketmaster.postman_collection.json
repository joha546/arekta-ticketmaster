    {
      "name": "06 Reservations",
      "description": "Phase 06",
      "item": [
        {
          "name": "POST Create Reservation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const current = pm.collectionVariables.get('idempotencyKey');",
                  "if (!current) {",
                  "  pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const id = json.reservation?.id;",
                  "  if (id) pm.collectionVariables.set('reservationId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
