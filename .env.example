# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8088
WEB_PORT=8088

# Database (Primary-Secondary-Secondary)
DATABASE_PRIMARY_URL=postgresql://app:app@localhost:5432/arekta-ticketmaster
DATABASE_REPLICA_1_URL=postgresql://app:app@localhost:5433/arekta-ticketmaster
DATABASE_REPLICA_2_URL=postgresql://app:app@localhost:5434/arekta-ticketmaster

# Redis (host port 6380 avoids conflict with a local Redis on 6379)
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# JWT (RS256) — generate dev keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Use ONE of these formats (Docker Compose cannot parse multi-line PEM blocks):
#   1) File path:  JWT_PRIVATE_KEY=./private.pem
#   2) Single line: JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
JWT_PRIVATE_KEY=./private.pem
JWT_PUBLIC_KEY=./public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email verification (Nodemailer SMTP — Mailpit for local dev)
EMAIL_FROM=noreply@arekta.local
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
APP_URL=http://localhost:3000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=api

# Frontend
VITE_API_BASE=/api
VITE_API_URL=http://localhost:3000

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:8088/reservations/success
STRIPE_CANCEL_URL=http://localhost:8088/reservations/cancel